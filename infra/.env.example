# Copy to infra/.env (gitignored) and adjust.
# These are read by docker compose from infra/.env automatically.

POSTGRES_DB=inetum
POSTGRES_USER=inetum
POSTGRES_PASSWORD=inetum

# OpenAI (LangChain4j). Leave empty to scaffold without API access; /ai/chat will then fail at request time.
OPENAI_API_KEY=
OPENAI_CHAT_MODEL=gpt-4o-mini
